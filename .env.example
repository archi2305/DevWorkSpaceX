# Database Configuration
POSTGRES_USER=devworkspace
POSTGRES_PASSWORD=devworkspace_password
POSTGRES_DB=devworkspace
DATABASE_URL=postgresql+psycopg2://devworkspace:devworkspace_password@localhost:5432/devworkspace

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Application Configuration
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
ENVIRONMENT=development
DEBUG=True
PROJECT_NAME=DevWorkspace X Backend

# CORS Configuration
CORS_ORIGINS=http://localhost,http://localhost:3000
OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# AWS Configuration (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Email Configuration (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=logs

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
